{
  "name": "resource_monitor",
  "version": "1.0.0",
  "description": "React coding dashboard with multi-language live execution",
  "main": "index.js",
  "scripts": {
    "start": "webpack-dev-server --config webpack/webpack.dev.config.js",
    "start:ui": "webpack-dev-server --config webpack/webpack.dev.config.js",
    "start:server": "node server/index.js",
    "seed": "node server/scripts/seed-initial-data.js",
    "dev": "concurrently \"npm run start:server\" \"npm run start:ui\"",
    "build": "webpack --mode production --config webpack/webpack.prod.config.js"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "clean-webpack-plugin": "^4.0.0",
    "concurrently": "^9.2.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "mini-css-extract-plugin": "^2.6.1",
    "mongoose": "^8.19.2",
    "react": "^16.14.0",
    "react-dom": "^16.14.0",
    "typescript": "^5.7.3"
  },
  "devDependencies": {
    "@babel/core": "^7.18.5",
    "@babel/preset-env": "^7.18.2",
    "@babel/preset-react": "^7.17.12",
    "babel-loader": "^8.2.5",
    "css-loader": "^7.1.2",
    "file-loader": "^6.2.0",
    "html-webpack-plugin": "^5.5.0",
    "sass": "^1.83.1",
    "sass-loader": "^16.0.4",
    "style-loader": "^4.0.0",
    "webpack": "^5.73.0",
    "webpack-cli": "^4.10.0",
    "webpack-dev-server": "^4.9.2",
    "webpack-merge": "^6.0.1"
  }
}
